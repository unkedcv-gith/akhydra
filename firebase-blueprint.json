{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "Un proyecto de ingeniería realizado por AKHYDRA.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "location": { "type": "string" },
        "mainArea": { "type": "string" },
        "description": { "type": "string" },
        "mainImage": { "type": "string" },
        "gallery": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "details": {
          "type": "object",
          "properties": {
            "hidraulica": { "type": "string" },
            "vial": { "type": "string" },
            "ambiental": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "location", "mainArea", "mainImage"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Colección de proyectos de la empresa."
    }
  }
}
