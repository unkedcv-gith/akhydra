rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Project validation helper
    function isValidProject(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.location is string && data.location.size() <= 200 &&
             data.mainImage is string && data.mainImage.size() <= 1000;
    }

    function isVerifiedUser() {
      return isSignedIn() && request.auth.token.email == "mesfede@gmail.com";
    }

    match /projects/{projectId} {
      allow read: if true;
      allow create: if isVerifiedUser() && isValidId(projectId) && isValidProject(incoming());
      allow update: if isVerifiedUser() && isValidId(projectId) && isValidProject(incoming());
      allow delete: if isVerifiedUser();
    }
  }
}
